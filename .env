# DeafChat configuration
HOST=0.0.0.0
PORT=8000
ENV=development

# Rooms
ROOM_EXPIRY_MINUTES=30
MAX_ROOM_MEMBERS=50
MAX_MESSAGE_LENGTH=2000
MAX_ACTIVE_ROOMS=500

# Audio
MAX_AUDIO_DURATION=120
MAX_AUDIO_SIZE=1500000

# Security
CORS_ORIGINS=https://deafchat.deafnews.it,http://localhost:8000
RATE_LIMIT_ROOMS=10/minute
RATE_LIMIT_API=30/minute

# TURN server (coturn) – set TURN_HOST to your server's public IP or domain
# Leave empty to use only STUN (won't work behind strict NAT / 4G / 5G)
TURN_HOST=46.224.187.181
TURN_PORT=3478
TURN_TLS_PORT=5349
TURN_USERNAME=deafchat
TURN_PASSWORD=deafchat-turn-secret

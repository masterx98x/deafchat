# DeafChat configuration
HOST=0.0.0.0
PORT=8000
ENV=production

# Rooms
ROOM_EXPIRY_MINUTES=30
MAX_ROOM_MEMBERS=50
MAX_MESSAGE_LENGTH=2000
MAX_ACTIVE_ROOMS=500

# Audio
MAX_AUDIO_DURATION=120
MAX_AUDIO_SIZE=1500000

# Security
# Leave empty when the frontend proxies /api and /ws to the backend from the same origin.
CORS_ORIGINS=
RATE_LIMIT_ROOMS=10/minute
RATE_LIMIT_API=30/minute
